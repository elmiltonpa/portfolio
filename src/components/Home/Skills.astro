---
const skills = [
    {
        title: "FULLSTACK DEVELOPMENT",
        description: "Building responsive web applications from the ground up, connecting clean user interfaces with robust logic.",
        items: ["Frontend Development", "API Integration", "Database Design"]
    },
    {
        title: "MODERN UI/UX",
        description: "Translating designs into pixel-perfect, accessible, and interactive user experiences.",
        items: ["Responsive Layouts", "Web Animation", "CSS Architecture"]
    },
    {
        title: "STRATEGIC LAYERING",
        description: "Consulting on the intersection of brand and build. Translating complex business goals into high-fidelity design outcomes.",
        items: ["Creative Direction", "Product Strategy", "Design Auditing"]
    }
];
---

<section id="skills" class="grid grid-cols-1 md:grid-cols-12 gap-16 mb-80">
    <div class="md:col-span-3">
        <h2
            class="font-headline text-2xl font-black uppercase tracking-tighter sticky top-40"
        >
            02
            <span class="block text-accent"
                >Capabilities</span
            >
        </h2>
    </div>
    <div class="md:col-span-9">
        <div class="space-y-32">
            {skills.map(skill => (
                <div class="group relative">
                    <h3
                        class="font-headline text-6xl md:text-8xl font-black uppercase tracking-tighter leading-none transition-all group-hover:pl-8"
                    >
                        {skill.title}
                    </h3>
                    <div
                        class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12 opacity-80"
                    >
                        <p class="font-body text-xl">
                            {skill.description}
                        </p>
                        <ul
                            class="font-label text-xs font-bold uppercase tracking-widest space-y-2"
                        >
                            {skill.items.map(item => (
                                <li class="flex items-center gap-2">
                                    <span
                                        class="w-2 h-2 bg-accent"
                                    ></span>
                                    {item}
                                </li>
                            ))}
                        </ul>
                    </div>
                </div>
            ))}
        </div>

        <div class="mt-40 border-t-2 border-primary pt-16">
            <h4 class="font-label text-xs font-black uppercase tracking-[0.2em] mb-12 text-primary/40">Core Tech Stack</h4>
            <div class="flex flex-wrap gap-4">
                {["TypeScript", "React", "Next.js", "Astro", "Node.js", "Rust", "PostgreSQL", "Redis", "Docker", "Git"].map(tech => (
                    <span class="font-headline text-3xl md:text-5xl font-black uppercase tracking-tighter border-2 border-primary/10 px-6 py-4 hover:bg-accent hover:text-white hover:border-accent transition-all duration-300 cursor-default">
                        {tech}
                    </span>
                ))}
            </div>
        </div>
    </div>
</section>
