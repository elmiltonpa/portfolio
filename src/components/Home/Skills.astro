---
const skills = [
  {
    title: "FULLSTACK DEVELOPMENT",
    description:
      "Building responsive web applications from the ground up, connecting clean user interfaces with robust logic.",
    items: ["Frontend Development", "API Integration", "Database Design"],
  },
  {
    title: "MODERN UI/UX",
    description:
      "Translating designs into pixel-perfect, accessible, and interactive user experiences.",
    items: ["Responsive Layouts", "Web Animation", "CSS Architecture"],
  },
  {
    title: "STRATEGIC LAYERING",
    description:
      "Consulting on the intersection of brand and build. Translating complex business goals into high-fidelity design outcomes.",
    items: ["Creative Direction", "Product Strategy", "Design Auditing"],
  },
];
---

<section
  id="skills"
  class="grid grid-cols-1 md:grid-cols-12 gap-8 sm:gap-12 md:gap-16 mb-40 sm:mb-60 md:mb-80"
>
  <div class="md:col-span-3">
    <h2
      class="font-headline text-xl sm:text-2xl font-black uppercase tracking-tighter sticky top-40 scroll-animate-right"
    >
      02
      <span class="block text-accent">Capabilities</span>
    </h2>
  </div>
  <div class="md:col-span-9">
    <div class="space-y-16 sm:space-y-24 md:space-y-32">
      {
        skills.map((skill, idx) => (
          <div class="group relative scroll-animate">
            <h3 class="font-headline text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-8xl font-black uppercase tracking-tighter leading-[0.95] sm:leading-none inline-block pr-2 md:pr-8 transition-transform duration-300 will-change-transform group-hover:translate-x-2 lg:group-hover:translate-x-8 break-words hyphens-auto">
              {skill.title}
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6 md:gap-8 mt-6 sm:mt-8 md:mt-12 opacity-80">
              <p class="font-body text-base sm:text-lg md:text-xl">
                {skill.description}
              </p>
              <ul class="font-label text-[10px] sm:text-xs font-bold uppercase tracking-widest space-y-1.5 sm:space-y-2">
                {skill.items.map((item) => (
                  <li class="flex items-center gap-2">
                    <span class="w-1.5 h-1.5 sm:w-2 sm:h-2 bg-accent shrink-0" />
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))
      }
    </div>

    <div
      class="mt-16 sm:mt-24 md:mt-40 border-t-2 border-primary pt-8 sm:pt-12 md:pt-16 scroll-animate"
    >
      <h4
        class="font-label text-[10px] sm:text-xs font-black uppercase tracking-[0.2em] mb-6 sm:mb-8 md:mb-12 text-primary/40"
      >
        Core Tech Stack
      </h4>
      <div class="flex flex-wrap gap-1.5 sm:gap-2 md:gap-4">
        {
          [
            "TypeScript",
            "React",
            "Next.js",
            "Astro",
            "Node.js",
            "Rust",
            "PostgreSQL",
            "Redis",
            "Docker",
            "Git",
          ].map((tech, idx) => (
            <span
              class="font-headline text-base sm:text-xl md:text-3xl lg:text-4xl xl:text-5xl font-black uppercase tracking-tighter border-2 border-primary/10 px-2 sm:px-3 md:px-4 lg:px-6 py-1.5 sm:py-2 md:py-3 lg:py-4 hover:bg-accent hover:text-white hover:border-accent transition-all duration-300 cursor-default animate-scale-in"
              style={`animation-delay: ${idx * 80}ms`}
            >
              {tech}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
