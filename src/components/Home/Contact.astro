---

---

<section id="contact" class="grid grid-cols-1 md:grid-cols-12 gap-16 mb-80">
  <div class="md:col-span-3">
    <h2
      class="font-headline text-2xl font-black uppercase tracking-tighter sticky top-40"
    >
      04
      <span class="block text-accent">Connect</span>
    </h2>
  </div>
  <div class="md:col-span-9">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      <div class="md:col-span-5">
        <p class="font-body text-3xl leading-tight text-primary mb-12">
          Do you have an idea in mind? <span class="italic text-accent"
            >Let's talk.</span
          >
        </p>
        <div class="space-y-12">
          <div class="border-t border-primary/10 pt-8">
            <span
              class="font-label text-xs font-black text-accent mb-4 block uppercase tracking-widest"
              >Direct Channel</span
            >
            <a
              href="mailto:elmiltonibarra@gmail.com"
              class="font-headline text-2xl font-black uppercase tracking-tighter hover:text-accent transition-colors"
            >
              elmiltonibarra@gmail.com
            </a>
          </div>
          <div class="border-t border-primary/10 pt-8">
            <span
              class="font-label text-xs font-black text-accent mb-4 block uppercase tracking-widest"
              >Social Structures</span
            >
            <div class="flex flex-col gap-4">
              <a
                href="https://www.linkedin.com/in/milton-ibarra-ba1020205/"
                target="_blank"
                class="font-headline text-xl font-bold uppercase tracking-tighter hover:text-accent transition-colors flex items-center gap-4 group"
              >
                LinkedIn
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform group-hover:translate-x-1 group-hover:-translate-y-1"
                >
                  <line x1="7" y1="17" x2="17" y2="7"></line>
                  <polyline points="7 7 17 7 17 17"></polyline>
                </svg>
              </a>
              <a
                href="https://github.com/elmiltonpa"
                target="_blank"
                class="font-headline text-xl font-bold uppercase tracking-tighter hover:text-accent transition-colors flex items-center gap-4 group"
              >
                GitHub
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform group-hover:translate-x-1 group-hover:-translate-y-1"
                >
                  <line x1="7" y1="17" x2="17" y2="7"></line>
                  <polyline points="7 7 17 7 17 17"></polyline>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
      <div class="md:col-span-7">
        <form
          action="https://formspree.io/f/your-id"
          method="POST"
          class="space-y-12 bg-border/20 p-8 md:p-12 border border-primary/5"
        >
          <div class="space-y-2">
            <label
              for="name"
              class="font-label text-[10px] font-black uppercase tracking-[0.2em] text-primary/40"
              >Full Name</label
            >
            <input
              type="text"
              name="name"
              id="name"
              required
              class="w-full bg-transparent border-b-2 border-primary/10 focus:border-accent outline-none py-4 font-body text-2xl transition-colors"
            />
          </div>
          <div class="space-y-2">
            <label
              for="email"
              class="font-label text-[10px] font-black uppercase tracking-[0.2em] text-primary/40"
              >Email Address</label
            >
            <input
              type="email"
              name="email"
              id="email"
              required
              class="w-full bg-transparent border-b-2 border-primary/10 focus:border-accent outline-none py-4 font-body text-2xl transition-colors"
            />
          </div>
          <div class="space-y-2">
            <label
              for="message"
              class="font-label text-[10px] font-black uppercase tracking-[0.2em] text-primary/40"
              >Project Brief</label
            >
            <textarea
              name="message"
              id="message"
              rows="4"
              required
              class="w-full bg-transparent border-b-2 border-primary/10 focus:border-accent outline-none py-4 font-body text-2xl transition-colors resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full bg-primary text-background font-headline text-xl font-black uppercase tracking-tighter py-6 hover:bg-accent transition-all duration-300"
          >
            Submit Requirement
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
