---

---

<section id="contact" class="grid grid-cols-1 md:grid-cols-12 gap-16 mb-80">
  <div class="md:col-span-3">
    <h2
      class="font-headline text-2xl font-black uppercase tracking-tighter sticky top-40"
    >
      04
      <span class="block text-accent">Connect</span>
    </h2>
  </div>
  <div class="md:col-span-9">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      <div class="md:col-span-5">
        <p class="font-body text-3xl leading-tight text-primary mb-12">
          Do you have an idea in mind? <span class="italic text-accent"
            >Let's talk.</span
          >
        </p>
        <div class="space-y-12">
          <div class="border-t border-primary/10 pt-8">
            <span
              class="font-label text-xs font-black text-accent mb-4 block uppercase tracking-widest"
              >Direct Channel</span
            >
            <a
              href="mailto:elmiltonibarra@gmail.com"
              class="font-headline text-2xl font-black uppercase tracking-tighter hover:text-accent transition-colors"
            >
              elmiltonibarra@gmail.com
            </a>
          </div>
          <div class="border-t border-primary/10 pt-8">
            <span
              class="font-label text-xs font-black text-accent mb-4 block uppercase tracking-widest"
              >Social Structures</span
            >
            <div class="flex flex-col gap-4">
              <a
                href="https://www.linkedin.com/in/milton-ibarra-ba1020205/"
                target="_blank"
                class="font-headline text-xl font-bold uppercase tracking-tighter hover:text-accent transition-colors flex items-center gap-4 group"
              >
                LinkedIn
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform group-hover:translate-x-1 group-hover:-translate-y-1"
                >
                  <line x1="7" y1="17" x2="17" y2="7"></line>
                  <polyline points="7 7 17 7 17 17"></polyline>
                </svg>
              </a>
              <a
                href="https://github.com/elmiltonpa"
                target="_blank"
                class="font-headline text-xl font-bold uppercase tracking-tighter hover:text-accent transition-colors flex items-center gap-4 group"
              >
                GitHub
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform group-hover:translate-x-1 group-hover:-translate-y-1"
                >
                  <line x1="7" y1="17" x2="17" y2="7"></line>
                  <polyline points="7 7 17 7 17 17"></polyline>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
      <div class="md:col-span-7">
        <form
          action="https://formspree.io/f/your-id"
          method="POST"
          class="flex flex-col gap-8"
        >
          <div class="relative group">
            <label
              for="name"
              class="font-label text-[10px] font-black uppercase tracking-[0.3em] text-primary/40 transition-colors group-focus-within:text-accent"
              >01. FULL NAME</label
            >
            <input
              type="text"
              name="name"
              id="name"
              placeholder="JOHN DOE"
              required
              class="w-full bg-transparent border-b-[3px] border-primary/20 focus:border-accent outline-none pt-2 pb-2 font-headline text-2xl md:text-3xl font-black tracking-tighter text-primary transition-colors placeholder-primary/10"
            />
          </div>
          <div class="relative group">
            <label
              for="email"
              class="font-label text-[10px] font-black uppercase tracking-[0.3em] text-primary/40 transition-colors group-focus-within:text-accent"
              >02. EMAIL ADDRESS</label
            >
            <input
              type="email"
              name="email"
              id="email"
              placeholder="HELLO@DOMAIN.COM"
              required
              class="w-full bg-transparent border-b-[3px] border-primary/20 focus:border-accent outline-none pt-2 pb-2 font-headline text-2xl md:text-3xl font-black tracking-tighter text-primary transition-colors placeholder-primary/10"
            />
          </div>
          <div class="relative group">
            <label
              for="message"
              class="font-label text-[10px] font-black uppercase tracking-[0.3em] text-primary/40 transition-colors group-focus-within:text-accent"
              >03. PROJECT DETAILS</label
            >
            <textarea
              name="message"
              id="message"
              rows="2"
              placeholder="TELL ME ABOUT YOUR IDEA..."
              required
              class="w-full bg-transparent border-b-[3px] border-primary/20 focus:border-accent outline-none pt-2 pb-2 font-headline text-xl md:text-2xl font-bold tracking-tighter text-primary transition-colors resize-none placeholder-primary/10 leading-none"
            ></textarea>
          </div>
          <div class="pt-4">
            <button
              type="submit"
              class="group w-full bg-primary text-background font-headline text-2xl md:text-3xl font-black uppercase tracking-tighter py-4 flex items-center justify-between px-6 hover:bg-accent hover:text-white transition-all duration-300"
            >
              <span>Send Message</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="4"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="transition-transform duration-300 group-hover:translate-x-2 group-hover:-translate-y-2"
              >
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
