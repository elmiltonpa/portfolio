---

---

<section
  id="contact"
  class="grid grid-cols-1 md:grid-cols-12 gap-8 sm:gap-12 md:gap-16 mb-40 sm:mb-60 md:mb-80"
>
  <div class="md:col-span-3">
    <h2
      class="font-headline text-xl sm:text-2xl font-black uppercase tracking-tighter sticky top-40 scroll-animate-right"
    >
      04
      <span class="block text-accent">Connect</span>
    </h2>
  </div>
  <div class="md:col-span-9">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 sm:gap-12">
      <div class="md:col-span-5">
        <p
          class="font-body text-xl sm:text-2xl md:text-3xl leading-tight text-primary mb-8 sm:mb-12 scroll-animate"
        >
          Do you have an idea in mind? <span class="italic text-accent"
            >Let's talk.</span
          >
        </p>
        <div class="space-y-8 sm:space-y-12">
          <div class="border-t border-primary/10 pt-6 sm:pt-8 scroll-animate">
            <span
              class="font-label text-[10px] sm:text-xs font-black text-accent mb-3 sm:mb-4 block uppercase tracking-widest"
              >Direct Channel</span
            >
            <a
              href="mailto:elmiltonibarra@gmail.com"
              class="font-headline text-base sm:text-lg md:text-xl font-black uppercase tracking-tighter hover:text-accent transition-colors whitespace-nowrap"
            >
              elmiltonibarra@gmail.com
            </a>
          </div>
          <div class="border-t border-primary/10 pt-6 sm:pt-8 scroll-animate">
            <span
              class="font-label text-[10px] sm:text-xs font-black text-accent mb-3 sm:mb-4 block uppercase tracking-widest"
              >Social Structures</span
            >
            <div class="flex flex-col gap-3 sm:gap-4">
              <a
                href="https://www.linkedin.com/in/milton-ibarra-ba1020205/"
                target="_blank"
                class="font-headline text-lg sm:text-xl font-bold uppercase tracking-tighter hover:text-accent transition-colors flex items-center gap-3 sm:gap-4 group"
              >
                LinkedIn
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform group-hover:translate-x-1 group-hover:-translate-y-1"
                >
                  <line x1="7" y1="17" x2="17" y2="7"></line>
                  <polyline points="7 7 17 7 17 17"></polyline>
                </svg>
              </a>
              <a
                href="https://github.com/elmiltonpa"
                target="_blank"
                class="font-headline text-lg sm:text-xl font-bold uppercase tracking-tighter hover:text-accent transition-colors flex items-center gap-3 sm:gap-4 group"
              >
                GitHub
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform group-hover:translate-x-1 group-hover:-translate-y-1"
                >
                  <line x1="7" y1="17" x2="17" y2="7"></line>
                  <polyline points="7 7 17 7 17 17"></polyline>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
      <div class="md:col-span-7">
        <form
          id="contact-form"
          action="https://formspree.io/f/xwvnbrod"
          method="POST"
          class="flex flex-col gap-6 sm:gap-8"
        >
          <div class="relative group scroll-animate">
            <label
              for="name"
              class="font-label text-[10px] font-black uppercase tracking-[0.3em] text-primary/40 transition-colors group-focus-within:text-accent"
              >01. FULL NAME</label
            >
            <input
              type="text"
              name="name"
              id="name"
              placeholder="JOHN DOE"
              required
              class="w-full bg-transparent border-b-[3px] border-primary/20 focus:border-accent outline-none pt-2 pb-2 font-headline text-xl sm:text-2xl md:text-3xl font-black tracking-tighter text-primary transition-colors placeholder-primary/10"
            />
          </div>
          <div class="relative group scroll-animate">
            <label
              for="email"
              class="font-label text-[10px] font-black uppercase tracking-[0.3em] text-primary/40 transition-colors group-focus-within:text-accent"
              >02. EMAIL ADDRESS</label
            >
            <input
              type="email"
              name="email"
              id="email"
              placeholder="HELLO@DOMAIN.COM"
              required
              class="w-full bg-transparent border-b-[3px] border-primary/20 focus:border-accent outline-none pt-2 pb-2 font-headline text-xl sm:text-2xl md:text-3xl font-black tracking-tighter text-primary transition-colors placeholder-primary/10"
            />
          </div>
          <div class="relative group scroll-animate">
            <label
              for="message"
              class="font-label text-[10px] font-black uppercase tracking-[0.3em] text-primary/40 transition-colors group-focus-within:text-accent"
              >03. PROJECT DETAILS</label
            >
            <textarea
              name="message"
              id="message"
              rows="2"
              placeholder="TELL ME ABOUT YOUR IDEA..."
              required
              class="w-full bg-transparent border-b-[3px] border-primary/20 focus:border-accent outline-none pt-2 pb-2 font-headline text-lg sm:text-xl md:text-2xl font-bold tracking-tighter text-primary transition-colors resize-none placeholder-primary/10 leading-none"
            ></textarea>
          </div>
          <div class="pt-2 sm:pt-4 scroll-animate">
            <button
              id="submit-button"
              type="submit"
              class="group w-full bg-primary text-background font-headline text-xl sm:text-2xl md:text-3xl font-black uppercase tracking-tighter py-3 sm:py-4 flex items-center justify-between px-4 sm:px-6 hover:bg-accent hover:text-white transition-all duration-300 cursor-pointer"
            >
              <span id="submit-text">Send Message</span>
              <svg
                id="submit-icon"
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="4"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="transition-transform duration-300 group-hover:translate-x-2 group-hover:-translate-y-2 w-5 h-5 sm:w-7 sm:h-7"
              >
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  function initContactForm() {
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const submitBtn = document.getElementById("submit-button") as HTMLButtonElement;
    const submitText = document.getElementById("submit-text");

    if (!form || !submitBtn || !submitText) return;

    // Prevent attaching multiple event listeners if re-initialized
    form.removeEventListener("submit", handleFormSubmit);
    form.addEventListener("submit", handleFormSubmit);

    async function handleFormSubmit(e: SubmitEvent) {
      e.preventDefault();

      const originalText = submitText!.textContent;
      submitText!.textContent = "SENDING...";
      submitBtn.classList.add("opacity-80", "pointer-events-none");

      const formData = new FormData(form);

      try {
        const response = await fetch(form.action, {
          method: form.method,
          body: formData,
          headers: {
            Accept: "application/json",
          },
        });

        if (response.ok) {
          form.reset();
          submitText!.textContent = "MESSAGE SENT!";
          submitBtn.classList.replace("bg-primary", "bg-accent");
          
          setTimeout(() => {
            submitText!.textContent = originalText;
            submitBtn.classList.remove("opacity-80", "pointer-events-none");
            submitBtn.classList.replace("bg-accent", "bg-primary");
          }, 4000);
        } else {
          submitText!.textContent = "ERROR. TRY AGAIN.";
          setTimeout(() => {
            submitText!.textContent = originalText;
            submitBtn.classList.remove("opacity-80", "pointer-events-none");
          }, 3000);
        }
      } catch (error) {
        submitText!.textContent = "NETWORK ERROR.";
        setTimeout(() => {
          submitText!.textContent = originalText;
          submitBtn.classList.remove("opacity-80", "pointer-events-none");
        }, 3000);
      }
    }
  }

  document.addEventListener("DOMContentLoaded", initContactForm);
  document.addEventListener("astro:page-load", initContactForm);
</script>
