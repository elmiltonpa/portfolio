---
import { Icon } from "astro-icon/components";
---

<div class="relative group" id="theme-wrapper" data-open="false">
    <button
        id="theme-toggle"
        class="relative p-2 rounded-lg bg-transparent text-muted-foreground hover:bg-secondary/50 hover:text-foreground group-data-[open=true]:bg-secondary/50 group-data-[open=true]:text-foreground transition-all duration-200 flex items-center justify-center active:scale-95"
        aria-label="Select theme"
        aria-haspopup="listbox"
        aria-expanded="false"
    >
        <Icon name="lucide:moon" class="size-5" />
    </button>

    <div
        id="theme-menu"
        class="absolute top-full mt-2 right-0 bg-card border border-border rounded-lg shadow-xl p-1.5 min-w-40 z-50 flex flex-col gap-1 origin-top-right transition-all duration-200 ease-out pointer-events-none opacity-0 invisible -translate-y-2 scale-95 group-data-[open=true]:opacity-100 group-data-[open=true]:visible group-data-[open=true]:translate-y-0 group-data-[open=true]:scale-100 group-data-[open=true]:pointer-events-auto"
    >
        <button
            class="w-full text-left px-3 py-2 rounded-md flex items-center gap-2 hover:bg-secondary/80 transition-colors text-sm font-medium text-muted-foreground hover:text-foreground"
            data-theme="gold"
        >
            <Icon name="lucide:star" class="size-4" />
            Gold Dark
        </button>
        <button
            class="w-full text-left px-3 py-2 rounded-md flex items-center gap-2 hover:bg-secondary/80 transition-colors text-sm font-medium text-muted-foreground hover:text-foreground"
            data-theme="purple"
        >
            <Icon name="lucide:gem" class="size-4" />
            Purple Dark
        </button>
        <button
            class="w-full text-left px-3 py-2 rounded-md flex items-center gap-2 hover:bg-secondary/80 transition-colors text-sm font-medium text-muted-foreground hover:text-foreground"
            data-theme="light"
        >
            <Icon name="lucide:sun" class="size-4" />
            Light
        </button>
    </div>
</div>

<script>
    const getTheme = () => {
        return localStorage.getItem("theme") || "gold";
    };

    const setTheme = (theme: string) => {
        document.documentElement.setAttribute("data-theme", theme);
        localStorage.setItem("theme", theme);
    };

    document.addEventListener("astro:page-load", () => {
        const currentTheme = getTheme();
        setTheme(currentTheme);

        const wrapper = document.getElementById("theme-wrapper");
        const toggle = document.getElementById("theme-toggle");
        const menu = document.getElementById("theme-menu");

        const closeMenu = () => {
            wrapper?.setAttribute("data-open", "false");
            toggle?.setAttribute("aria-expanded", "false");
        };

        toggle?.addEventListener("click", () => {
            const isOpen = wrapper?.getAttribute("data-open") === "true";
            wrapper?.setAttribute("data-open", String(!isOpen));
            toggle?.setAttribute("aria-expanded", String(!isOpen));
        });

        document.addEventListener("click", (e) => {
            if (!wrapper?.contains(e.target as Node)) {
                closeMenu();
            }
        });

        menu?.addEventListener("click", (e) => {
            const target = (e.target as HTMLElement).closest("[data-theme]");
            if (target) {
                const newTheme = target.getAttribute("data-theme")!;
                setTheme(newTheme);
                closeMenu();
            }
        });
    });
</script>
