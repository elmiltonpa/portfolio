---
import ThemeToggle from "../components/ui/ThemeToggle.astro";
---

<nav
    class="fixed top-0 left-0 w-full z-50 bg-background border-b-0"
>
    <div
        class="flex justify-between items-center w-full px-12 py-8 max-w-screen-2xl mx-auto"
    >
        <div
            class="text-2xl font-black tracking-tighter text-primary font-headline uppercase"
        >
            <a href="/">MILTON<span class="text-accent">.</span>IBARRA</a>
        </div>
        <div class="hidden md:flex gap-12">
            <a
                class="font-headline uppercase tracking-tighter font-bold text-primary hover:text-accent transition-colors"
                href="#projects">PROJECTS</a
            >
            <a
                class="font-headline uppercase tracking-tighter font-bold text-primary hover:text-accent transition-colors"
                href="#skills">SKILLS</a
            >
            <a
                class="font-headline uppercase tracking-tighter font-bold text-primary hover:text-accent transition-colors"
                href="#about">ABOUT</a
            >
            <a
                class="font-headline uppercase tracking-tighter font-bold text-primary hover:text-accent transition-colors"
                href="#contact">CONTACT</a
            >
        </div>
        <div class="flex items-center gap-6">
            <ThemeToggle />
            <a
                href="#contact"
                class="font-headline uppercase tracking-tighter font-bold px-6 py-2 bg-primary text-background hover:bg-accent transition-all"
            >
                GET IN TOUCH
            </a>
        </div>
    </div>
</nav>
