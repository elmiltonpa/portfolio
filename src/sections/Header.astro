---
import ThemeToggle from "../components/ui/ThemeToggle.astro";
---

<nav class="fixed top-0 left-0 w-full z-50 bg-background border-b-0">
  <div
    class="flex justify-between items-center w-full px-4 sm:px-6 md:px-12 py-4 md:py-8 max-w-screen-2xl mx-auto"
  >
    <div
      class="text-base sm:text-lg md:text-2xl font-black tracking-tighter text-primary font-headline uppercase shrink-0"
    >
      <a href="/">MILTON<span class="text-accent">.</span>IBARRA</a>
    </div>

    <div class="hidden lg:flex gap-8 xl:gap-12">
      <a
        class="font-headline uppercase tracking-tighter font-bold text-primary hover:text-accent transition-colors text-sm xl:text-base"
        href="#projects">PROJECTS</a
      >
      <a
        class="font-headline uppercase tracking-tighter font-bold text-primary hover:text-accent transition-colors text-sm xl:text-base"
        href="#skills">SKILLS</a
      >
      <a
        class="font-headline uppercase tracking-tighter font-bold text-primary hover:text-accent transition-colors text-sm xl:text-base"
        href="#about">ABOUT</a
      >
      <a
        class="font-headline uppercase tracking-tighter font-bold text-primary hover:text-accent transition-colors text-sm xl:text-base"
        href="#contact">CONTACT</a
      >
    </div>

    <div class="flex items-center gap-2 sm:gap-3 md:gap-6">
      <ThemeToggle />

      <button
        id="mobile-menu-btn"
        class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 group"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span
          class="w-6 h-0.5 bg-primary transition-all duration-300 origin-center group-[.menu-open]:rotate-45 group-[.menu-open]:translate-y-2"
        ></span>
        <span
          class="w-6 h-0.5 bg-primary transition-all duration-300 group-[.menu-open]:opacity-0"
        ></span>
        <span
          class="w-6 h-0.5 bg-primary transition-all duration-300 origin-center group-[.menu-open]:-rotate-45 group-[.menu-open]:-translate-y-2"
        ></span>
      </button>

      <a
        href="#contact"
        class="hidden sm:block font-headline text-[10px] sm:text-xs md:text-base uppercase tracking-tighter font-bold px-3 sm:px-4 md:px-6 py-2 bg-primary text-background hover:bg-accent transition-all whitespace-nowrap"
      >
        GET IN TOUCH
      </a>
    </div>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-background translate-x-full transition-transform duration-500 ease-out lg:hidden"
>
  <div class="flex flex-col justify-center items-center h-full gap-8 px-8">
    <a
      href="#projects"
      class="mobile-nav-link font-headline text-4xl sm:text-5xl font-black uppercase tracking-tighter text-primary hover:text-accent transition-colors"
    >
      PROJECTS
    </a>
    <a
      href="#skills"
      class="mobile-nav-link font-headline text-4xl sm:text-5xl font-black uppercase tracking-tighter text-primary hover:text-accent transition-colors"
    >
      SKILLS
    </a>
    <a
      href="#about"
      class="mobile-nav-link font-headline text-4xl sm:text-5xl font-black uppercase tracking-tighter text-primary hover:text-accent transition-colors"
    >
      ABOUT
    </a>
    <a
      href="#contact"
      class="mobile-nav-link font-headline text-4xl sm:text-5xl font-black uppercase tracking-tighter text-primary hover:text-accent transition-colors"
    >
      CONTACT
    </a>

    <div class="mt-8 pt-8 border-t border-primary/10 w-full max-w-xs">
      <a
        href="#contact"
        class="mobile-nav-link block w-full text-center font-headline text-lg uppercase tracking-tighter font-bold px-6 py-4 bg-primary text-background hover:bg-accent transition-all"
      >
        GET IN TOUCH
      </a>
    </div>
  </div>
</div>

<script>
  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");

  let isOpen = false;

  function toggleMenu() {
    isOpen = !isOpen;

    if (isOpen) {
      menuBtn?.classList.add("menu-open");
      mobileMenu?.classList.remove("translate-x-full");
      mobileMenu?.classList.add("translate-x-0");
      document.body.style.overflow = "hidden";
      menuBtn?.setAttribute("aria-expanded", "true");
    } else {
      menuBtn?.classList.remove("menu-open");
      mobileMenu?.classList.add("translate-x-full");
      mobileMenu?.classList.remove("translate-x-0");
      document.body.style.overflow = "";
      menuBtn?.setAttribute("aria-expanded", "false");
    }
  }

  function closeMenu() {
    if (isOpen) {
      toggleMenu();
    }
  }

  menuBtn?.addEventListener("click", toggleMenu);

  // Close menu when clicking a link
  mobileNavLinks.forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  // Close menu on escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && isOpen) {
      closeMenu();
    }
  });

  // Close menu on resize to desktop
  window.addEventListener("resize", () => {
    if (window.innerWidth >= 1024 && isOpen) {
      closeMenu();
    }
  });
</script>
